# ===========================================
# Agente Cleexs — variables de entorno
# Copiá a .env (local) o configurá en Easypanel
# ===========================================

# --- Base de datos (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agente_cleexs?schema=public

# --- API (Fastify) ---
API_PORT=4000
JWT_SECRET=cambiar-por-secreto-largo-y-aleatorio
CRON_SECRET=cambiar-por-secreto-cron
FRONTEND_URL=https://agents.cleexs.net
FRONTEND_URLS=https://agents.cleexs.net,http://localhost:3000

# Scheduler autónomo de Teo (true = desactivado)
DISABLE_AUTONOMOUS=true
AUTONOMOUS_TICK_MS=3600000

# Seed inicial al arrancar (solo primera vez en producción)
RUN_DB_SEED=true

# --- Web (Next.js) — build-time en Easypanel ---
NEXT_PUBLIC_API_URL=https://api-agents.cleexs.net

# --- WordPress (Cleexs) ---
WORDPRESS_URL=https://cleexs.net
WORDPRESS_USERNAME=tu-email@ejemplo.com
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WORDPRESS_APPROVAL_STATUS=draft
WORDPRESS_CATEGORY_ID=18
# Nombre del autor en WordPress (el usuario WP debe tener este display name → "Por Teo")
WORDPRESS_AUTHOR_NAME=Teo

# --- Google métricas (GSC + GA4) — proyecto GCP "Cleexs" ---
# JSON completo de la service account (una línea en Easypanel)
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=https://cleexs.net/
GA4_PROPERTY_ID=

# --- WhatsApp (Baileys self-hosted en EasyPanel) ---
# URL interna del bot (Easypanel: http://cleexs-wa-bot:3008)
BAILEYS_BOT_URL=
# Puente hacia diagnóstico Cleexs (Railway)
CLEEXS_API_URL=https://api.cleexs.net
WHATSAPP_CHANNEL_API_KEY=
# Fallback BuilderBot Cloud (opcional mientras migrás)
# BUILDERBOT_BOT_ID=
# BUILDERBOT_API_KEY=
# BUILDERBOT_BASE_URL=https://app.builderbot.cloud

# --- Opcional: OpenAI (fase LLM) ---
# OPENAI_API_KEY=
